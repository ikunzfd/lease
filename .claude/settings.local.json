{
  "permissions": {
   "allow": [
     "Read",        
     "Write",       
     "Bash(npm *)",  
     "Bash(git *)",   
     "Bash(node *)"   
   ],
   "deny": [
     "Bash(rm -rf *)" 
   ]
  },
  "hooks": {
   "PostToolUse": [
     {
      "matcher": "Write|Edit",
      "hooks": [
        {
         "type": "command",
         "command": "echo \"文件已修改，建议检查一下改了什么\""
        }
      ]
     }
   ]
  },
  "autoCompactThreshold": 80
}